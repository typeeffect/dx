// Target example: Bayesian linear regression via probabilistic effects
//
// Source: dx-03/src/test/resources/programs/prob_bayesian.dx
// Status: semantic target — not yet parser-stable in dx-bootstrap
//
// Model: y_i ~ Normal(a * x_i + b, 1.0)
// Prior: a ~ Normal(0, 5), b ~ Normal(0, 5)
// Inference: importance sampling (likelihood weighting)
//
// This is the first multi-parameter Bayesian model in the target package.

effect prob:
    sample(dist: Str, mu: Float, sigma: Float) -> Float
    observe(dist: Str, mu: Float, sigma: Float, value: Float) -> Float
.

// ── Data: y = 2*x + 1 ──

val xs = [0.0, 1.0, 2.0, 3.0]
val ys = [1.1, 3.0, 4.9, 7.1]

// ── Model ──

fun regression_model() -> (Float, Float) !prob:
    val a = sample("normal", 0.0, 5.0)
    val b = sample("normal", 0.0, 5.0)
    observe("normal", a * xs[0] + b, 1.0, ys[0])
    observe("normal", a * xs[1] + b, 1.0, ys[1])
    observe("normal", a * xs[2] + b, 1.0, ys[2])
    observe("normal", a * xs[3] + b, 1.0, ys[3])
    (a, b)
.

// ── Importance sampling handler ──

val n_samples = 2000
var w_sum_a = 0.0
var w_sum_b = 0.0
var w_total = 0.0

for i in 0..n_samples - 1:
    var log_w = 0.0
    val (a, b) = handle regression_model() with:
        prob'sample(dist, mu, sigma) ->
            resume(normal_sample(mu, sigma))
        prob'observe(dist, mu, sigma, value) ->
            log_w = log_w + normal_log_pdf(value, mu, sigma)
            resume(value)
    .
    val w = exp(log_w)
    w_sum_a = w_sum_a + a * w
    w_sum_b = w_sum_b + b * w
    w_total = w_total + w
.

val mean_a = w_sum_a / w_total
val mean_b = w_sum_b / w_total

// True: a ≈ 2.0, b ≈ 1.0
assert(mean_a > 0.5)
assert(mean_a < 4.0)
assert(mean_b > -1.0)
assert(mean_b < 3.0)

// Key design points:
//
// 1. The model is a pure function with prob effects — it never knows
//    which inference algorithm is running.
//
// 2. The handler implements importance sampling. Swapping the handler
//    would give MCMC, HMC, or variational inference — same model.
//
// 3. Multiple observe() calls accumulate log-likelihood naturally.
//
// 4. This pattern composes with AD: if the model used smooth operations,
//    nesting a smooth handler inside prob would give gradient-based inference.
