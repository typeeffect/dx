# Draft .dxprim artifact — auto-derived backward rule (NOT YET IMPLEMENTED)
#
# This artifact shows rule_kind = "generated": the compiler symbolically
# differentiated the forward body to derive the backward rule at refresh time.
# No handwritten backward block was needed.
#
# Compare with sigmoid.dxprim.example which uses rule_kind = "explicit_backward".

[primitive]
format_version = "0.1.0"
name = "square"
rule_kind = "generated"
source_fingerprint = "sha256:e5f6a7b8c9d0..."
generated_at = "2026-03-29T17:00:00Z"

[signature]
params = [{ name = "x", type = "Float" }]
return_type = "Float"

[forward]
body = "x * x"

[backward]
# This section was GENERATED by the compiler, not written by the user.
# The compiler symbolically differentiated the forward body during
# `dx prim refresh` and locked the result here.
params = [{ name = "x", type = "Float" }, { name = "dout", type = "Float" }]
return_type = "Float"
body = "2.0 * x * dout"

# Notes:
#
# - rule_kind "generated" means the backward rule was auto-derived.
#   The user wrote only the forward body; the compiler did the rest.
#
# - rule_kind "explicit_backward" (see sigmoid.dxprim.example) means
#   the user provided a hand-written backward rule, typically for
#   numerical stability or efficiency.
#
# - Normal builds read this artifact and trust the locked backward rule.
#   They never re-derive it. Only `dx prim refresh` re-derives.
