# Draft .dxschema artifact format (design reference, not yet implemented)
#
# This file shows the intended shape of a locked schema artifact.
# It is produced by `dx schema refresh` and consumed by normal builds.
#
# Key properties:
# - deterministic: same source → same artifact
# - reviewable: plain text, suitable for version control
# - offline-capable: normal builds never query the datasource

[schema]
format_version = "0.1.0"
name = "Customers"
provider = "csv"
source = "data/customers.csv"
source_fingerprint = "sha256:a1b2c3d4e5f6..."
schema_fingerprint = "sha256:f6e5d4c3b2a1..."
generated_at = "2026-03-29T10:00:00Z"

[fields]
id = { type = "Int", nullable = false }
name = { type = "Str", nullable = false }
email = { type = "Str", nullable = true }
region = { type = "Str", nullable = false }
lifetime_value = { type = "Int", nullable = false }
signup_date = { type = "Str", nullable = true }

# Notes:
# - `type` maps to DX type system (Int, Str, Float, Bool)
# - `nullable` produces Option(T) in the generated Row type
# - `source_fingerprint` detects when the datasource definition changes
# - `schema_fingerprint` detects when the actual schema changes
# - stale artifacts cause build warnings, not silent failures
