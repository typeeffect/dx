--- match_if_in_every_arm
## If expression inside every arm of a match
fun f(x: T, flag: Bool) -> Str:
    match x:
        Ok(v):
            if flag:
                "ok-yes"
            else:
                "ok-no"
            .
        Err(e):
            if flag:
                "err-yes"
            else:
                "err-no"
            .
        _:
            "default"
    .
.

